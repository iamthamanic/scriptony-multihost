#!/usr/bin/env bash
# ECC verify pre-push: deterministic checks (no shim AI review).
# Full legacy gate: npm run checks (Appwrite deploy / release).
echo "pre-push: Running npm run verify..."
bash scripts/run-verify.sh
exit_code=$?
if [ $exit_code -ne 0 ]; then
  echo "pre-push: verify FAILED. Push aborted. Fix issues or run @ecc-check."
  exit 1
fi
echo "pre-push: verify passed. Pushing..."
exit 0
