# Supabase backups: alle SQL/Dump ignorieren, nur LATEST versionieren
supabase/backups/*.sql
supabase/backups/*.dump
!supabase/backups/schema_and_data_LATEST.sql

# Env / secrets (never commit)
.env
.env.local
.env.migration
.env.*.local
.env.shim.local
scripts/.env
scripts/.env.migration

# Build output & dependencies
build/
node_modules/
functions/node_modules/
# Bundled Appwrite function entry (rebuild with: cd functions && npm run build:scriptony-ai)
functions/scriptony-ai/index.js
.appwrite-deploy/
functions/.deploy-staging/
starter-for-react/
deno.lock
functions/deno.lock
repo-visualization*.html

# OS
.DS_Store
.vercel

# shimwrappercheck
.shimwrapper/
.shim/

# Local IDE / agent caches (not part of the app)
.pi/
**/.pi-lens/

# LightRAG index data (local only)
.rag/
scriptony-blender-addon.zip
scriptony_blender_addon.zip
scriptony_blender_extension.zip
# Blender build artifacts
tools/blender/dist/*
eslint-fix.mjs
