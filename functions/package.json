{
  "name": "scriptony-multihost-functions",
  "private": true,
  "type": "module",
  "scripts": {
    "build:scriptony-ai": "esbuild scriptony-ai/index.ts --bundle --platform=node --target=node16 --format=cjs --outfile=scriptony-ai/index.js --legal-comments=none --inject:scriptony-ai/inject-node16-streams.cjs",
    "build:appwrite-deploy": "node build-appwrite-deploy.mjs",
    "appwrite:bootstrap-scriptony-ai": "node ./scripts/appwrite-bootstrap-scriptony-ai.mjs",
    "migrate:api-keys-feature": "node scripts/migrate-api-keys-feature.mjs",
    "appwrite:ensure-api-keys-feature": "node scripts/ensure-api-keys-feature-attribute.mjs",
    "setup:api-keys-feature": "node scripts/setup-api-keys-feature.mjs",
    "appwrite:inspect-databases": "node scripts/appwrite-inspect-databases.mjs",
    "provision-schema": "node ./tools/provision-appwrite-schema.mjs",
    "provision-buckets": "node ./tools/provision-appwrite-buckets.mjs",
    "delete-collection": "node ./tools/delete-appwrite-collection.mjs"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "node-appwrite": "^22.1.3",
    "undici": "^5.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
