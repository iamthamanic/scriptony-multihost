{
  "name": "scriptony-local-bridge",
  "version": "0.1.0",
  "description": "Local Bridge daemon — connects Appwrite Cloud with ComfyUI and Blender",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --external:dotenv --external:node-appwrite --external:zod",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "node-appwrite": "^22.1.3",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "vitest": "^3.1.2"
  }
}