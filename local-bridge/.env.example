# Local Bridge environment configuration
# Copy to .env and fill in your values

# Appwrite self-hosted connection (Docker internal URL when running in compose)
BRIDGE_APPWRITE_ENDPOINT=http://localhost:8080/v1
BRIDGE_APPWRITE_PROJECT_ID=your-project-id
BRIDGE_APPWRITE_API_KEY=your-api-key
BRIDGE_APPWRITE_DATABASE_ID=scriptony

# ComfyUI local instance
BRIDGE_COMFYUI_URL=http://127.0.0.1:8188

# Blender Addon local instance (Ticket 10)
BRIDGE_BLENDER_URL=http://127.0.0.1:9876

# Appwrite Storage bucket for render outputs
BRIDGE_STORAGE_BUCKET=shots

# Workflow templates directory (relative to cwd)
BRIDGE_WORKFLOWS_DIR=./workflows

# Health check server port
BRIDGE_HEALTH_PORT=9877

# Log level: debug | info | warn | error
BRIDGE_LOG_LEVEL=info