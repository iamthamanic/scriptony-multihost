# Copy to .env.shim.local (gitignored). Loaded by scripts/run-checks.sh for shim / AI review only.
# Vite (.env.local) does NOT pass these variables to npm run checks.

# Ollama Cloud (default host https://api.ollama.com) — required for SHIM_AI_REVIEW_PROVIDER=ollama
# Get a key from https://ollama.com — used as: Authorization: Bearer <key>
OLLAMA_API_KEY=your-ollama-cloud-key-here

# Optional overrides (also set in .shimwrappercheckrc):
# OLLAMA_HOST=https://api.ollama.com
# SHIM_OLLAMA_MODEL=glm-5.1
