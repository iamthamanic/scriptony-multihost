# Copy to .env.local (not committed). Vite dev uses port 3000 — see vite.config.ts.
# Optional: listen on all interfaces (LAN) — default is 127.0.0.1 only.
# VITE_DEV_BIND_ALL=1
#
# Scriptony Runtime Profile: "local" | "cloud" | "selfHosted"
# - local      = solo desktop (no login, file-based, Tauri/Electron)
# - cloud      = hosted Appwrite (default when unset)
# - selfHosted = custom Appwrite endpoint
# VITE_SCRIPTONY_RUNTIME=local
#
# Appwrite (browser): endpoint + project only — never put API keys here.
# Scriptony HTTP backends: NOT the same as VITE_APPWRITE_ENDPOINT unless you run a reverse proxy that maps
# /scriptony-* to Appwrite Functions. Appwrite serves each function on its own HTTP domain (Console → Functions → Domains),
# while this repo builds URLs as {BASE}/{functionName}/{route} — you need a proxy that matches that, or adjust BASE per setup.

VITE_APPWRITE_ENDPOINT=http://localhost:8080/v1
VITE_APPWRITE_PROJECT_ID=

# Path-style gateway: {BASE}/scriptony-projects/projects — only if you run a reverse proxy that maps those paths.
# Server-only CLI/setup helpers: never use VITE_ for secrets.
#
# Deploy (scripts/deploy-appwrite-function.sh): The Appwrite CLI does NOT read this file by default.
# This script sources .env.local and, if all of the following are set, runs `appwrite client` before upload:
#   - APPWRITE_API_KEY (or APPWRITE_APIKEY) — must include scope **functions.write** (Console → API Keys → Permissions)
#   - APPWRITE_ENDPOINT (optional if VITE_APPWRITE_ENDPOINT is set — same value is mirrored)
#   - APPWRITE_PROJECT_ID (optional if VITE_APPWRITE_PROJECT_ID is set)
# Self-signed HTTPS: APPWRITE_SELF_SIGNED_CERT=true
# CLI/Sever mismatch warning: try APPWRITE_NPX_CLI=appwrite-cli@17.3.1 (example) if deploy fails after auth is fixed.
# APPWRITE_API_KEY=
# Alias (also accepted by setup scripts): APPWRITE_APIKEY=

VITE_APPWRITE_FUNCTIONS_BASE_URL=
VITE_BACKEND_API_BASE_URL=

# Recommended for Appwrite Functions: each function’s HTTP domain (Console → Functions → scriptony-* → Domains).
# Single line, double quotes inside JSON. Request URL = domain + route (e.g. …/projects), not …/scriptony-projects/projects.
# Für KI muss `scriptony-ai` erreichbar sein; für Cover-/Legacy-Routen zusätzlich `scriptony-image`
# und bei Bedarf `scriptony-assistant`.
# Beispiel (Domains aus der Appwrite Console kopieren):
# Welten / Worldbuilding: Key scriptony-worldbuilding (POST /worlds). Ohne diesen Eintrag schlägt „Welt erstellen“ fehl.
# Film timeline editorial clips (Phase 1): add "scriptony-clips" to the map so /clips routes resolve.
# VITE_BACKEND_FUNCTION_DOMAIN_MAP={"scriptony-projects":"https://…","scriptony-clips":"https://…","scriptony-worldbuilding":"https://…","scriptony-ai":"https://…","scriptony-image":"https://…","scriptony-auth":"https://…","scriptony-mcp-appwrite":"https://…"}
VITE_BACKEND_FUNCTION_DOMAIN_MAP=

# Local dev only: if function HTTPS URLs fail with ERR_CERT_AUTHORITY_INVALID, use HTTP :8080 for the same host.
# VITE_DEV_FUNCTIONS_USE_HTTP=true
# Optional: comma-separated hostnames allowed as Vite dev proxy targets (besides localhost + Appwrite API host from VITE_APPWRITE_ENDPOINT).
# VITE_DEV_PROXY_EXTRA_HOSTS=scriptony-projects.mycompany.net
# Optional: override world list request timeout (ms). Defaults to API_CONFIG.REQUEST_TIMEOUT.
# VITE_WORLDS_API_TIMEOUT_MS=10000
# Optional (functions): cap list sizes to keep synchronous HTTP calls below timeout windows.
# SCRIPTONY_PROJECTS_LIST_LIMIT=500
# SCRIPTONY_WORLDS_LIST_LIMIT=500

VITE_APP_WEB_URL=http://localhost:3000
VITE_AUTH_REDIRECT_URL=http://localhost:3000
VITE_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password

# Capacitor / Tauri OAuth callback (custom URL scheme). Also register scriptony://auth-callback in Appwrite Console.
# VITE_CAPACITOR_URL_SCHEME=scriptony
# VITE_CAPACITOR_CALLBACK_HOST=auth-callback

# Desktop: default is cloud until local mode is product-ready (T38). Use explicit local only when intended:
# VITE_SCRIPTONY_RUNTIME=cloud
# VITE_SCRIPTONY_ALLOW_BROWSER_LOCAL=1   # DEV ONLY: local mode in browser (auth bypass — never production)

# Optional: some routes accept a public token in addition to the user JWT.
VITE_BACKEND_PUBLIC_TOKEN=

# Optional (npm run dev only): same URL as scriptony-assistant in VITE_BACKEND_FUNCTION_DOMAIN_MAP — Vite proxies it so
# the browser calls localhost (no cross-origin CORS). Production builds ignore this.
# VITE_DEV_PROXY_SCRIPTONY_ASSISTANT_TARGET=http://scriptony-assistant.appwrite.example.com:8080
