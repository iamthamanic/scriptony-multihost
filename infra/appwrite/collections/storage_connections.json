{
  "$id": "storage_connections",
  "name": "storage_connections",
  "databaseId": "scriptony-dev",
  "enabled": true,
  "documentSecurity": true,
  "attributes": [
    {
      "key": "user_id",
      "type": "string",
      "required": true,
      "size": 36
    },
    {
      "key": "provider",
      "type": "string",
      "required": true,
      "size": 50
    },
    {
      "key": "access_token_ciphertext",
      "type": "string",
      "required": true,
      "size": 10000
    },
    {
      "key": "refresh_token_ciphertext",
      "type": "string",
      "required": false,
      "size": 10000
    },
    {
      "key": "created_at",
      "type": "datetime",
      "required": true
    }
  ],
  "indexes": [
    {
      "key": "idx_user_id",
      "type": "key",
      "attributes": ["user_id"]
    },
    {
      "key": "idx_user_provider",
      "type": "key",
      "attributes": ["user_id", "provider"]
    }
  ]
}
